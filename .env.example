# ---- Data sources ----
API_FOOTBALL_KEY=
ODDS_API_KEY=

OPENROUTER_API_KEY=
USE_FREE_MODELS=false

# ---- Secret "Human Challenger" feature (optional) ----
# Passphrase that unlocks the hidden /challenger betting console (reached via the Konami
# code on the site). Leave EMPTY to disable the feature entirely. CHALLENGER_NAME is the
# human's display/leaderboard name (kept hidden from public boards until CHALLENGER_PUBLIC
# is flipped on in config.py).
CHALLENGER_KEY=
CHALLENGER_NAME=You

# ---- Read-only "friend" bet endpoint (optional) ----
# Shared key for GET /api/external/bet (model pick/stake/reasoning). EMPTY = route 404s.
FRIEND_API_KEY=

# ---- Visitor geography (public audience widget, optional) ----
# Shared secret the Next edge (/track) sends to the backend (/api/track) so the public can't
# forge visits. EMPTY = ingest disabled (POST /api/track 404s, no visits recorded). The Next
# side needs the SAME value in web/.env.local (gitignored) — see deploy/README "Visitor
# geography". The raw client IP is never stored; only derived country/region.
TRACK_INGEST_KEY=
# `{ip}`-templated free geo-IP endpoint. Default works without a key.
GEO_LOOKUP_URL=https://ipwho.is/{ip}
