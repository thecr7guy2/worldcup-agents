[Unit]
Description=Run the World Cup Agents tick every 15 minutes

[Timer]
# Every 15 minutes. The pre-kickoff path now has two distinct windows — late update
# (~T-75) then predict/bet (~T-50) — so the tick must fire at least once inside each;
# 15 min guarantees that separation. The tick is a free no-op when nothing is due.
OnCalendar=*:0/15
Persistent=true
RandomizedDelaySec=30

[Install]
WantedBy=timers.target
