[Unit]
Description=World Cup Agents — Next.js showcase site (the Arena)
After=network-online.target wc-api.service
Wants=network-online.target

[Service]
Type=simple
User=__USER__
WorkingDirectory=__REPO__/web
# Node lives outside the default service PATH; __NODE_DIR__ is filled in by install-web.sh.
Environment=PATH=__NODE_DIR__:/usr/local/bin:/usr/bin:/bin
Environment=NODE_ENV=production
# The browser sees one origin: next.config rewrites /api/* to the local uvicorn process.
Environment=API_PROXY=http://127.0.0.1:8001
# `next start` serves the production build (run `npm run build` at deploy first).
ExecStart=__NPM__ run start
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
