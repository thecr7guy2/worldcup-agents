[Unit]
Description=World Cup Agents — read-only JSON API for the showcase site (uvicorn)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__USER__
WorkingDirectory=__REPO__
# --no-sync: the venv is built once at deploy. WorkingDirectory is load-bearing —
# the API opens worldcup.db (and .env via Settings) relative to cwd. Bound to localhost;
# only the Next server (wc-web) reaches it, via its /api proxy.
ExecStart=__UV__ run --no-sync uvicorn worldcup_agents.web.app:app --host 127.0.0.1 --port 8001
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
